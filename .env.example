# Backend server port
PORT=8787

# Your Sportradar API key
SPORTRADAR_API_KEY=replace-with-your-key

# Option A: Full combine endpoint URL from your Sportradar product docs
# (If set, this takes priority over the fields below.)
# SPORTRADAR_COMBINE_URL=https://api.sportradar.com/draft/nfl/trial/v1/en/2026/prospects.json

# Option B: SDK-style fields (matches nflProspects params)
SPORTRADAR_ACCESS_LEVEL=trial
SPORTRADAR_LANGUAGE_CODE=en
SPORTRADAR_DRAFT_YEAR=2026
SPORTRADAR_FORMAT=json

# Frontend toggle: true = backend real API, false = local simulation
VITE_USE_REAL_DATA=true
